---
import { Image } from 'astro:assets';
import logoImg from '../assets/LOGO_5.png'; 
---

<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

<nav id="main-nav" class="fixed top-0 w-full z-50 bg-linear-to-b from-[#112A40] to-[#537FA6] border-gray-200 transition-all duration-500 py-5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
    
    <div class="shrink-0" 
         data-aos="fade-right" 
         data-aos-duration="1200" 
         data-aos-once="true">
      <a href="/" class="block">
        <Image 
          src={logoImg} 
          alt="J&R Consultores" 
          id="nav-logo"
          class="h-20 w-auto transition-all duration-300 hover:brightness-110"
          loading="eager" 
        />
      </a>
    </div>

    <div class="hidden md:block">
      <div class="ml-10 flex items-baseline space-x-8 font-medium">
        <a href="#" class="group relative px-2 py-1 text-white transition-all duration-300" data-aos="fade-down" data-aos-delay="200">
          <span>Inicio</span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-300 transition-all duration-300 group-hover:w-full"></span>
        </a>
        
        <a href="#" class="group relative px-2 py-1 text-white transition-all duration-300" data-aos="fade-down" data-aos-delay="400">
          <span>Servicios</span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-300 transition-all duration-300 group-hover:w-full"></span>
        </a>
        
        <a href="#" class="group relative px-2 py-1 text-white transition-all duration-300" data-aos="fade-down" data-aos-delay="600">
          <span>Nosotros</span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-300 transition-all duration-300 group-hover:w-full"></span>
        </a>

        <a href="#contacto" 
           class="bg-[#537FA6] text-white px-5 py-2 rounded-lg hover:bg-blue-600 hover:scale-105 hover:shadow-lg transition-all duration-300"
           data-aos="zoom-in" 
           data-aos-delay="800">
          Contacto
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  import AOS from 'aos';

  // Inicializar AOS
  AOS.init({
    duration: 1000,
    once: true,
  });

  const nav = document.querySelector('#main-nav') as HTMLElement;
  const logo = document.querySelector('#nav-logo') as HTMLElement;

  if (nav && logo) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        // Estado contraído: py-2 y fondo un poco más sólido o con sombra
        nav.classList.replace('py-5', 'py-2');
        nav.classList.add('shadow-xl', 'backdrop-blur-sm');
        logo.classList.replace('h-20', 'h-14');
      } else {
        // Estado original
        nav.classList.replace('py-2', 'py-5');
        nav.classList.remove('shadow-xl', 'backdrop-blur-sm');
        logo.classList.replace('h-14', 'h-20');
      }
    });
  }
</script>

<style>
  /* Mejoramos la visibilidad del subrayado sobre el fondo azul */
  .group:hover span {
    color: #e0f2fe; /* light blue 100 */
  }
</style>