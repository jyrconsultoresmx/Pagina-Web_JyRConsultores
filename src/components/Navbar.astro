---
import { Image } from 'astro:assets';
import logoImg from '../assets/LOGO_5.png'; 
---

<link rel="stylesheet" href="https://unpkg.com/aos@next/dist/aos.css" />

<nav id="main-nav" class="fixed top-0 w-full z-50 bg-linear-to-b from-[#112A40] to-[#537FA6] border-gray-200 transition-all duration-500 py-5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center">
    <div class="shrink-0" 
         data-aos="fade-right" 
         data-aos-duration="1200" 
         data-aos-once="true">
      <a href="/" aria-label="Ir al inicio de J&R Consultores" class="block">
        <Image 
          src={logoImg} 
          alt="J&R Consultores" 
          id="nav-logo"
          width={240}
          height={200}
          class="h-28 w-auto transition-all duration-300 hover:brightness-110"
          loading="eager" 
          decoding="sync"
        />
      </a>
    </div>

    <div class="hidden md:block">
      <div class="ml-10 flex items-baseline space-x-8 font-medium">
        <a href="#inicio" class="group relative px-2 py-1 text-white transition-all duration-300" data-aos="fade-down" data-aos-delay="200">
          <span>Inicio</span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-300 transition-all duration-300 group-hover:w-full"></span>
        </a>

        <a href="#nosotros" class="group relative px-2 py-1 text-white transition-all duration-300" data-aos="fade-down" data-aos-delay="400">
          <span>Nosotros</span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-300 transition-all duration-300 group-hover:w-full"></span>
        </a>
        
        <a href="#servicios" class="group relative px-2 py-1 text-white transition-all duration-300" data-aos="fade-down" data-aos-delay="600">
          <span>Servicios</span>
          <span class="absolute bottom-0 left-0 w-0 h-0.5 bg-blue-300 transition-all duration-300 group-hover:w-full"></span>
        </a>

        <a href="#contacto" 
           class="bg-[#537FA6] text-white px-5 py-2 rounded-lg hover:bg-blue-600 hover:scale-105 hover:shadow-lg transition-all duration-300"
           data-aos="zoom-in" 
           data-aos-delay="800">
          Contacto
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  import AOS from 'aos';
  import 'aos/dist/aos.css'

  AOS.init({
    duration: 1000,
    once: true,
  });

  // Lógica de cambio de tamaño del navbar al hacer scroll
  const nav = document.querySelector('#main-nav') as HTMLElement;
  const logo = document.querySelector('#nav-logo') as HTMLElement;

  if (nav && logo) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 50) {
        nav.classList.replace('py-5', 'py-2');
        nav.classList.add('shadow-xl', 'backdrop-blur-sm');
        logo.classList.replace('h-28', 'h-14');
      } else {
        nav.classList.replace('py-2', 'py-5');
        nav.classList.remove('shadow-xl', 'backdrop-blur-sm');
        logo.classList.replace('h-14', 'h-28');
      }
    });
  }

  const setupSmoothScroll = () => {
    const links = document.querySelectorAll('a[href^="#"]');
    
    links.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const targetId = link.getAttribute('href');
        if (!targetId || targetId === '#') return;

        const targetElement = document.querySelector(targetId);
        if (targetElement) {
          const navOffset = 100; 
          const targetPosition = targetElement.getBoundingClientRect().top + window.scrollY - navOffset;
          const startPosition = window.scrollY;
          const distance = targetPosition - startPosition;
          const duration = 1000;
          let start: number | null = null;

          const step = (timestamp: number) => {
            if (!start) start = timestamp;
            const progress = timestamp - start;
            const percentage = Math.min(progress / duration, 1);
            
            const easing = percentage < 0.5 
              ? 4 * percentage * percentage * percentage 
              : 1 - Math.pow(-2 * percentage + 2, 3) / 2;

            window.scrollTo(0, startPosition + distance * easing);

            if (progress < duration) {
              window.requestAnimationFrame(step);
            }
          };
          window.requestAnimationFrame(step);
        }
      });
    });
  };

  setupSmoothScroll();
  document.addEventListener('astro:page-load', setupSmoothScroll);
</script>

<style is:global>
  #inicio, #nosotros, #servicios, #contacto {
    scroll-margin-top: 100px;
  }
  
  @media (max-width: 768px) {
    section[id] {
      scroll-margin-top: 80px;
    }
  }
</style>