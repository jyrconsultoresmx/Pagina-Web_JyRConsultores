---
import { Icon } from "astro-icon/components";

const servicios = [
    {
        id: "cumplimiento",
        nombre: "Cumplimiento Fiscal",
        icon: "lucide:shield-check",
    },
    { id: "ingresos", nombre: "Ingresos Mixtos", icon: "lucide:layers" },
    {
        id: "regularizacion",
        nombre: "Regularización",
        icon: "lucide:file-text",
    },
    { id: "prevencion", nombre: "Prevención", icon: "lucide:search-check" },
];
---

<section id="contacto" class="py-24 bg-white px-6 font-sans">
    <div class="max-w-4xl mx-auto">
        <div class="text-center mb-16">
            <h2 class="text-5xl font-black text-slate-900 tracking-tight mb-3">
                Hablemos de tu caso
            </h2>
            <p class="text-slate-500 text-lg">
                Déjanos tus datos y un asesor especializado te contactará en
                menos de 24 horas.
            </p>
        </div>

        <form
            class="bg-[#fdfeff] p-8 md:p-12 rounded-[2rem] shadow-[0_10px_40px_-15px_rgba(0,0,0,0.08)] border border-slate-100"
            action="/api/send-email"
            method="POST"
            id="contactForm"
        >
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
                <div aria-hidden="true" style="position: absolute; left: -9999px;">
                    <label for="fax_empresa">Fax de la empresa</label>
                    <input type="text" id="fax_empresa" name="fax_empresa" tabindex="-1" autocomplete="off" />
                </div>
                <div class="flex flex-col gap-2">
                    <label for="nombre" class="text-sm font-bold text-slate-700"
                        >Nombre completo *</label
                    >
                    <input
                        type="text"
                        id="nombre"
                        name="nombre"
                        required
                        placeholder="Ej. Juan Pérez"
                        class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all outline-none"
                    />
                </div>
                <div class="flex flex-col gap-2">
                    <label
                        for="empresa"
                        class="text-sm font-bold text-slate-700"
                        >Empresa <span class="text-slate-400 font-normal"
                            >(Opcional)</span
                        ></label
                    >
                    <input
                        type="text"
                        id="empresa"
                        name="empresa"
                        placeholder="Ej. Consultores SC"
                        class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all outline-none"
                    />
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">
                <div class="flex flex-col gap-2">
                    <label for="email" class="text-sm font-bold text-slate-700"
                        >Correo electrónico *</label
                    >
                    <input
                        type="email"
                        id="email"
                        name="email"
                        required
                        placeholder="tu@empresa.com"
                        class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all outline-none"
                    />
                </div>
                <div class="flex flex-col gap-2">
                    <label
                        for="telefono"
                        class="text-sm font-bold text-slate-700"
                        >Teléfono *</label
                    >
                    <input
                        type="tel"
                        id="telefono"
                        name="telefono"
                        required
                        placeholder="A 10 dígitos"
                        class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all outline-none"
                    />
                </div>
            </div>

            <div class="mb-10">
                <label class="block text-sm font-bold text-slate-700 mb-4"
                    >¿En qué podemos ayudarte? *</label
                >
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    {
                        servicios.map((s) => (
                            <label class="relative cursor-pointer group">
                                <input
                                    type="radio"
                                    name="servicio"
                                    value={s.id}
                                    class="peer sr-only"
                                    required
                                />
                                <div class="flex flex-col items-center justify-center p-4 rounded-xl border-2 border-slate-100 bg-white hover:border-blue-200 peer-checked:border-blue-600 peer-checked:bg-blue-50 transition-all text-center h-full">
                                    <Icon
                                        name={s.icon}
                                        class="w-6 h-6 mb-2 text-slate-400 group-hover:text-blue-500 peer-checked:text-blue-600 transition-colors"
                                    />
                                    <span class="text-xs font-bold text-slate-600 peer-checked:text-blue-900">
                                        {s.nombre}
                                    </span>
                                </div>
                            </label>
                        ))
                    }
                </div>
            </div>

            <div class="flex flex-col gap-2 mb-8">
                <label for="mensaje" class="text-sm font-bold text-slate-700"
                    >Detalles de tu situación fiscal</label
                >
                <textarea
                    id="mensaje"
                    name="mensaje"
                    rows="4"
                    placeholder="Describe brevemente el motivo de tu consulta..."
                    class="px-4 py-3 rounded-xl border border-slate-200 bg-slate-50 focus:bg-white focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all outline-none resize-none"
                ></textarea>
            </div>

            <div class="flex items-start gap-3 mb-10">
                <input
                    type="checkbox"
                    id="privacidad"
                    name="privacidad"
                    required
                    class="mt-1 w-4 h-4 text-blue-600 bg-slate-100 border-slate-300 rounded focus:ring-blue-500 cursor-pointer"
                />
                <label
                    for="privacidad"
                    class="text-sm text-slate-600 cursor-pointer"
                >
                    Acepto las <a
                        href="/aviso-privacidad"
                        class="text-blue-600 font-semibold hover:underline"
                        >Políticas de Privacidad</a
                    > y el tratamiento de mis datos personales.
                </label>
            </div>


            <script is:inline src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
            <div class="flex justify-center mb-10 w-full overflow-hidden rounded-xl">
                <div 
                    class="cf-turnstile" 
                    data-sitekey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY}
                    data-theme="light"
                    data-language="es"
                    data-size="normal"
                ></div>
            </div>
            <button
                type="submit"
                class="w-full md:w-auto md:min-w-[250px] cursor-pointer mx-auto block bg-slate-900 hover:bg-blue-600 text-white font-bold py-4 px-10 rounded-xl transition-all duration-300 shadow-lg hover:shadow-blue-200 active:scale-95"
            >
                Solicitar Asesoría
            </button>
        </form>
    </div>
</section>

<script>
    import Swal from 'sweetalert2';

    // Configuración global del Toast de SweetAlert2 (reutilizable)
    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end', // Esquina superior derecha
        showConfirmButton: false, // Sin botones, se cierra solo
        timer: 4000, // 4 segundos
        timerProgressBar: true,
        didOpen: (toast) => {
            toast.addEventListener('mouseenter', Swal.stopTimer)
            toast.addEventListener('mouseleave', Swal.resumeTimer)
        },
        // Personalización de colores usando la paleta del sitio
        customClass: {
            popup: 'rounded-xl border border-slate-200 shadow-lg',
            title: 'text-sm font-bold text-slate-900',
        },
        background: '#ffffff',
    });

    const form = document.getElementById("contactForm") as HTMLFormElement;

    form?.addEventListener("submit", async (e) => {
        e.preventDefault();
        
        // Bloqueo del botón para UX
        const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.innerText = "Procesando...";

        const formData = new FormData(form);

        try {
            const response = await fetch("/api/send-email", {
                method: "POST",
                body: formData,
            });

            const result = await response.json();

            if (response.ok && result.success) {
                // Notificación Toast de ÉXITO
                Toast.fire({
                    icon: 'success',
                    title: '¡Consulta enviada con éxito!',
                    // Personalizamos la barra de progreso con el azul del sitio
                    willOpen: (toast) => {
                        const progressBar = toast.querySelector('.swal2-timer-progress-bar') as HTMLElement;
                        if (progressBar) progressBar.style.backgroundColor = '#3b82f6';
                    }
                });
                form.reset();
            } else {
                throw new Error(result.message || 'Error desconocido');
            }
        } catch (error) {
            // Notificación Toast de ERROR
            Toast.fire({
                icon: 'error',
                title: 'Hubo un error al enviar tu mensaje.',
                text: 'Por favor intenta más tarde.',
                willOpen: (toast) => {
                    const progressBar = toast.querySelector('.swal2-timer-progress-bar') as HTMLElement;
                    if (progressBar) progressBar.style.backgroundColor = '#ef4444';
                }
            });
        } finally {
            // Restauración del botón
            submitBtn.disabled = false;
            submitBtn.innerText = "Solicitar Asesoría";
        }
    });
</script>